# AILEX Backend — Variables de Entorno
# Copiar este archivo como .env y completar los valores

# Base de datos
DATABASE_URL=postgresql://ailex_user:password@localhost:5432/ailex_db

# AI Provider (futura integración)
AI_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Configuración general
APP_NAME=AILEX
APP_VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# OCR local (requiere Tesseract OCR y Poppler instalados en el sistema)
OCR_LANGUAGE=spa
OCR_MIN_TEXT_CHARS=80
OCR_MAX_PDF_PAGES=40
OCR_MAX_FILE_SIZE_MB=25
OCR_DPI=200
OCR_TIMEOUT_SECONDS=30
OCR_POPPLER_PATH=
OCR_TESSERACT_CMD=

# Confianza
DEFAULT_CONFIDENCE_THRESHOLD=0.7
MIN_SOURCES_FOR_ASSERTION=2
