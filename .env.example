# AILEX Backend - Variables de Entorno
# Copiar este archivo como .env y completar los valores

# Base de datos
DATABASE_URL=postgresql://ailex_user:password@localhost:5432/ailex_db

# AI Provider (futura integracion)
AI_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Configuracion general
APP_NAME=AILEX
APP_VERSION=0.1.0
DEBUG=true
AILEX_ENV=dev
CORS_ORIGINS=http://localhost:3000

# Product environment / usage guardrails
# AILEX_ENV = dev | beta | prod
# dev  -> sin limite de uso
# beta -> limite configurable
# prod -> limite configurable
# USAGE_GUARDRAIL_ENABLED=
# USAGE_GUARDRAIL_HEAVY_QUERY_LIMIT=50
# USAGE_GUARDRAIL_HEAVY_QUERY_WINDOW_SECONDS=60
# USAGE_GUARDRAIL_HEAVY_QUERY_BURST_LIMIT=3
# USAGE_GUARDRAIL_HEAVY_QUERY_BURST_WINDOW_SECONDS=3
# USAGE_GUARDRAIL_READ_LIMIT=120
# USAGE_GUARDRAIL_READ_WINDOW_SECONDS=60
# USAGE_GUARDRAIL_CONTROL_LIMIT=30
# USAGE_GUARDRAIL_CONTROL_WINDOW_SECONDS=60

# OCR local (requiere Tesseract OCR y Poppler instalados en el sistema)
OCR_LANGUAGE=spa
OCR_MIN_TEXT_CHARS=80
OCR_MAX_PDF_PAGES=40
OCR_MAX_FILE_SIZE_MB=25
OCR_DPI=200
OCR_TIMEOUT_SECONDS=30
OCR_POPPLER_PATH=
OCR_TESSERACT_CMD=

# Confianza
DEFAULT_CONFIDENCE_THRESHOLD=0.7
MIN_SOURCES_FOR_ASSERTION=2
